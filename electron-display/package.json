{
  "name": "tprezpro-display",
  "version": "1.6.0",
  "description": "Timer Display overlay - transparent floating window synced with Firebase",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build-all": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tprezpro.display",
    "productName": "Timer Display",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "display.html",
      "room-input.html",
      "package.json"
    ]
  }
}
